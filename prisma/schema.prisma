generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String      @unique
  passwordHash         String

  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  subscriptionStatus   String?
  subscriptionPriceId  String?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  sheets               LabelSheet[]
}

model LabelSheet {
  id          String      @id @default(cuid())
  userId      String
  title       String
  eventName   String?
  totalLabels Int         @default(10)
  settings    Json?
  logoUrl     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  items       LabelItem[]
}

model LabelItem {
  id            String     @id @default(cuid())
  sheetId       String
  positionIndex Int
  foodName      String?
  diets         Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sheet         LabelSheet @relation(fields: [sheetId], references: [id])

  @@unique([sheetId, positionIndex])
}