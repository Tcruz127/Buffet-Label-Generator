generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String      @unique
  passwordHash         String

  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  subscriptionStatus   String?
  subscriptionPriceId  String?
  cancelAtPeriodEnd    Boolean     @default(false)
  currentPeriodEnd     DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  sheets               LabelSheet[]
  memberships          OrganizationMember[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]
  invites   OrganizationInvite[]
  sheets    LabelSheet[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           String       @default("member") // owner | member
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           String       @default("member")
  token          String       @unique @default(cuid())
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model LabelSheet {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  title          String
  eventName      String?
  totalLabels    Int           @default(10)
  settings       Json?
  logoUrl        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  items          LabelItem[]
  dishAnalyses   DishAnalysis[]
}

model LabelItem {
  id            String         @id @default(cuid())
  sheetId       String
  positionIndex Int
  foodName      String?
  description   String?
  diets         Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  sheet         LabelSheet     @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  analyses      DishAnalysis[]

  @@unique([sheetId, positionIndex])
}

model IngredientRule {
  id                 String    @id @default(cuid())
  ingredientName     String
  normalizedName     String    @unique

  containsGluten     Boolean   @default(false)
  containsDairy      Boolean   @default(false)
  containsEgg        Boolean   @default(false)
  containsSoy        Boolean   @default(false)
  containsNuts       Boolean   @default(false)
  containsShellfish  Boolean   @default(false)
  containsSesame     Boolean   @default(false)

  isVegetarian       Boolean?
  isVegan            Boolean?

  confidence         String?   // low | medium | high
  notes              String?
  source             String?   // manual | chef_bot | imported
  verified           Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model DishAnalysis {
  id                    String      @id @default(cuid())
  sheetId               String
  labelItemId           String?

  foodName              String?
  description           String?

  matchedIngredients    Json?
  suggestedDiets        Json?
  possibleDiets         Json?
  cannotVerify          Json?

  confidence            String?     // low | medium | high
  reasoning             String?
  warnings              String?

  status                String      @default("unreviewed")
  // unreviewed | suggested | verified | needs_clarification

  reviewedBy            String?
  reviewedAt            DateTime?

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  sheet                 LabelSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  labelItem             LabelItem?  @relation(fields: [labelItemId], references: [id], onDelete: SetNull)

  @@index([sheetId])
  @@index([labelItemId])
}